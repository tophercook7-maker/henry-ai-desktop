# Dependencies
node_modules/

# Build output
dist/
dist-electron/
release/

# Vite / test / lint caches (local only)
.vite/
coverage/
.eslintcache

# macOS duplicate-drop folder name (never commit)
scripts 2/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Database (user data, not committed)
*.db
*.db-journal
*.db-wal

# TypeScript incremental / project-info caches (never commit)
*.tsbuildinfo
tsconfig.node.tsbuildinfo

# macOS Finder duplicates (space + number copies)
*\ 2.ts
*\ 2.tsx
*\ 2.css
*\ 2.js
.DS_Store


# Build outputs — generated on every build, do not track
renderer/assets/
dist/
dist-electron/


# macOS Finder / iCloud copy artifacts (e.g. "file 2.tsx", "file 4.tsx")
*\ [0-9]*\.*
henry-proxy/.wrangler/
release2/

# Local archive of byte-identical numbered duplicates (created 2026-05-26)
.archive-*/

# Backups created by editing sessions (`*.before-*`, `*.backup-*`, and
# iCloud-numbered duplicates) moved here by tooling so they stay out of
# git and the typecheck globs.
_backups/
