{
  "name": "henry-ai-desktop",
  "version": "3.0.5",
  "description": "Henry AI — Local-first desktop AI operating system with dual-engine architecture",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Topher Cook",
    "email": "hello@henryai.app"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite.web.config.ts",
    "dev:electron": "vite",
    "build:web": "vite build --config vite.web.config.ts",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win --x64",
    "build:linux": "vite build && electron-builder --linux --x64",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run typecheck && vitest run && vite build",
    "rebuild": "npx @electron/rebuild",
    "build:mac:unsigned": "vite build && electron-builder --mac --config.mac.identity=null --config.compression=normal",
    "push": "git push \"https://${GITHUB_PERSONAL_ACCESS_TOKEN}@github.com/tophercook7-maker/henry-ai-desktop.git\" main",
    "cap:build": "npm run build:web && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "postinstall": "npx @electron/rebuild || true",
    "build:win:arm64": "vite build && electron-builder --win --arm64",
    "build:mac:signed": "vite build && electron-builder --mac --arm64",
    "release": "vite build && electron-builder --mac --win --publish always"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/generative-ai": "^0.17.0",
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^11.1.2",
    "electron-updater": "^6.3.0",
    "expo": "^55.0.26",
    "highlight.js": "^11.10.0",
    "lucide-react": "^0.436.0",
    "mqtt": "^5.15.1",
    "node-cron": "^4.2.1",
    "openai": "^4.56.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.1",
    "react-native": "^0.83.9",
    "react-router-dom": "^6.26.0",
    "three": "^0.184.0",
    "uuid": "^10.0.0",
    "ws": "^8.21.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.2.0",
    "@types/trusted-types": "^2.0.7",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.41",
    "prettier": "^3.8.2",
    "rollup": "^4.60.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "ai.henry.desktop",
    "productName": "Henry AI",
    "icon": "build/icon.icns",
    "directories": {
      "output": "release2"
    },
    "files": [
      "renderer/**",
      "dist-electron/**",
      "electron/python/**",
      "!node_modules/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "tophercook7-maker",
      "repo": "henry-ai-desktop",
      "private": false,
      "releaseType": "release"
    },
    "mac": {
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Henry uses the microphone so you can talk to him — audio is transcribed locally on your Mac and never uploaded."
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "identity": "Christopher Cook (NFS22LSQRC)"
    },
    "dmg": {
      "sign": false,
      "title": "Henry AI ${version}",
      "icon": "build/icon.icns",
      "iconSize": 80,
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Henry AI",
      "artifactName": "Henry-AI-Setup-${version}-${arch}.exe",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installer-header.bmp",
      "license": "LICENSE",
      "warningsAsErrors": false
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "afterSign": "scripts/notarize.cjs",
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": true
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
